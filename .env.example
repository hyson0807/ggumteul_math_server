# --- 필수 ---
# Neon Postgres 연결 문자열. Pooler 엔드포인트 권장 (?sslmode=require).
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require

# JWT 시크릿 (openssl rand -base64 64 등으로 생성)
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

# 허용할 프론트 도메인(쉼표 구분). production에서 미설정 시 모든 origin 차단됨.
CORS_ORIGIN=https://your-app-domain.com

# --- 선택 (소셜 로그인 사용 시) ---
GOOGLE_CLIENT_ID=
GOOGLE_IOS_CLIENT_ID=
GOOGLE_ANDROID_CLIENT_ID=
APPLE_BUNDLE_ID=

# --- 선택 (앱 강제 업데이트 사용 시) ---
APP_MINIMUM_VERSION=1.0.0
APP_STORE_URL_IOS=
APP_STORE_URL_ANDROID=

# --- Railway 자동 주입 ---
# PORT, NODE_ENV
